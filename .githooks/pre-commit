#!/bin/sh
# Blocks direct commits to main. Create a branch first: feature/... or fix/...

branch=$(git symbolic-ref --short HEAD 2>/dev/null)

if [ "$branch" = "main" ]; then
  echo "✗ Direct commits to main are not allowed." >&2
  echo "  Create a branch first, e.g.: git checkout -b feature/short-description" >&2
  exit 1
fi

exit 0
